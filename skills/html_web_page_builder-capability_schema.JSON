{
  "capability_schema_version": "1.0",
  "capability": {
    "id": "html_web_page_builder",
    "name": "HTML Web Page Builder",
    "description": "Generates complete, responsive, accessible HTML web pages (and optional CSS/JS assets) from natural language, structured specs, or markdown content.",
    "category": "web_generation",
    "tags": [
      "html",
      "css",
      "javascript",
      "responsive",
      "accessibility",
      "seo",
      "static-site",
      "landing-page",
      "ui"
    ],
    "version": "1.0.0",
    "status": "stable"
  },
  "contracts": {
    "input": {
      "type": "object",
      "required": ["request"],
      "additionalProperties": false,
      "properties": {
        "request": {
          "type": "string",
          "description": "Natural language description of the desired page or component set."
        },
        "mode": {
          "type": "string",
          "enum": ["minimal", "styled", "production", "component"],
          "default": "styled",
          "description": "Controls output complexity and included best practices."
        },
        "page_type": {
          "type": "string",
          "enum": [
            "landing_page",
            "marketing_page",
            "documentation_page",
            "portfolio",
            "dashboard_shell",
            "blog_post",
            "form_page",
            "pricing_page",
            "custom"
          ],
          "default": "custom"
        },
        "content": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "markdown": {
              "type": "string",
              "description": "Optional markdown to be converted into sections and content blocks."
            },
            "structured_sections": {
              "type": "array",
              "description": "Optional explicit section plan (overrides inferred layout when provided).",
              "items": {
                "type": "object",
                "required": ["id", "type", "title"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string" },
                  "type": {
                    "type": "string",
                    "enum": [
                      "header",
                      "hero",
                      "features",
                      "testimonials",
                      "pricing",
                      "faq",
                      "gallery",
                      "cta",
                      "content",
                      "form",
                      "footer",
                      "custom"
                    ]
                  },
                  "title": { "type": "string" },
                  "body": { "type": "string", "description": "Optional copy/content for the section." },
                  "items": {
                    "type": "array",
                    "description": "Optional item list (e.g., features/testimonials/pricing tiers).",
                    "items": { "type": "object" }
                  }
                }
              }
            },
            "assets": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "logo_url": { "type": "string" },
                "images": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "favicon_url": { "type": "string" }
              }
            }
          }
        },
        "design": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "theme": {
              "type": "string",
              "enum": ["light", "dark", "system"],
              "default": "system"
            },
            "brand_tone": {
              "type": "string",
              "enum": ["minimal", "playful", "corporate", "editorial", "bold", "luxury", "retro", "custom"],
              "default": "minimal"
            },
            "color_palette": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "primary": { "type": "string", "description": "CSS color value, e.g. #6D28D9" },
                "secondary": { "type": "string" },
                "background": { "type": "string" },
                "surface": { "type": "string" },
                "text": { "type": "string" },
                "muted": { "type": "string" }
              }
            },
            "typography": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "font_family": { "type": "string", "description": "e.g., system-ui, Inter, etc." },
                "base_font_size_px": { "type": "number", "default": 16 }
              }
            },
            "layout": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "max_width_px": { "type": "number", "default": 1120 },
                "grid": { "type": "string", "enum": ["flex", "grid", "mixed"], "default": "mixed" },
                "spacing_scale": { "type": "string", "enum": ["compact", "normal", "airy"], "default": "normal" }
              }
            }
          }
        },
        "tech": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "css_strategy": {
              "type": "string",
              "enum": ["internal", "external", "inline", "tailwind_classes"],
              "default": "internal"
            },
            "js_level": {
              "type": "string",
              "enum": ["none", "basic", "interactive"],
              "default": "basic"
            },
            "include_reset": { "type": "boolean", "default": true },
            "include_dark_mode_toggle": { "type": "boolean", "default": false },
            "framework_target": {
              "type": "string",
              "enum": ["none", "react_ready", "vue_ready", "svelte_ready"],
              "default": "none",
              "description": "If set, outputs HTML structured to be easily lifted into the target framework."
            }
          }
        },
        "quality": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "a11y_level": {
              "type": "string",
              "enum": ["baseline", "wcag_aa"],
              "default": "baseline"
            },
            "seo_level": {
              "type": "string",
              "enum": ["none", "basic", "enhanced"],
              "default": "basic"
            },
            "performance_level": {
              "type": "string",
              "enum": ["none", "basic", "optimized"],
              "default": "basic"
            }
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "format": {
              "type": "string",
              "enum": ["single_html", "multi_file_bundle", "component_snippets"],
              "default": "single_html"
            },
            "bundle_files": {
              "type": "array",
              "description": "When format=multi_file_bundle, list the desired files.",
              "items": {
                "type": "string",
                "enum": ["index.html", "styles.css", "app.js", "README.md"]
              },
              "default": ["index.html", "styles.css", "app.js"]
            },
            "include_comments": {
              "type": "boolean",
              "default": true,
              "description": "Whether to include brief explanatory comments in output."
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["artifacts", "summary"],
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "object",
          "required": ["title", "sections", "notes"],
          "additionalProperties": false,
          "properties": {
            "title": { "type": "string" },
            "sections": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "type", "title"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string" },
                  "type": { "type": "string" },
                  "title": { "type": "string" }
                }
              }
            },
            "notes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Important implementation notes, assumptions, or follow-ups."
            }
          }
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["kind", "filename", "content"],
            "additionalProperties": false,
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["html", "css", "js", "markdown", "snippet"]
              },
              "filename": { "type": "string" },
              "content": { "type": "string" },
              "content_type": {
                "type": "string",
                "enum": ["text/html", "text/css", "text/javascript", "text/markdown", "text/plain"]
              }
            }
          }
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "a11y_checks": {
              "type": "array",
              "items": { "type": "string" }
            },
            "seo_checks": {
              "type": "array",
              "items": { "type": "string" }
            },
            "assumptions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "warnings": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "execution": {
    "steps": [
      {
        "id": "parse_intent",
        "description": "Interpret request, infer page goals, audience, and content structure.",
        "inputs": ["request", "content", "page_type", "mode"],
        "outputs": ["inferred_outline"]
      },
      {
        "id": "compose_layout",
        "description": "Create semantic section layout and navigation scaffolding; ensure responsive strategy.",
        "inputs": ["inferred_outline", "design.layout"],
        "outputs": ["layout_plan"]
      },
      {
        "id": "apply_style",
        "description": "Generate CSS according to theme, palette, typography, and spacing scale.",
        "inputs": ["layout_plan", "design", "tech.css_strategy"],
        "outputs": ["css_artifact"]
      },
      {
        "id": "enhance_interactions",
        "description": "Add optional JS for navigation, form validation, toggles, and basic interactivity.",
        "inputs": ["layout_plan", "tech.js_level", "tech.include_dark_mode_toggle"],
        "outputs": ["js_artifact"]
      },
      {
        "id": "generate_artifacts",
        "description": "Emit final artifacts in requested format (single file, bundle, or snippets).",
        "inputs": ["layout_plan", "css_artifact", "js_artifact", "output.format"],
        "outputs": ["artifacts"]
      },
      {
        "id": "quality_pass",
        "description": "Run accessibility/SEO/performance heuristics and return diagnostics.",
        "inputs": ["artifacts", "quality"],
        "outputs": ["diagnostics"]
      }
    ]
  },
  "guardrails": {
    "security": [
      "Do not inject unsafe scripts or third-party resources unless explicitly requested.",
      "Avoid embedding secrets, tokens, or credentials in output.",
      "Prefer progressive enhancement; JS should not be required for core content visibility."
    ],
    "html_quality": [
      "Always include <!DOCTYPE html>, <meta charset>, and responsive viewport meta tag.",
      "Use semantic landmarks (header/main/footer/nav) when applicable.",
      "Ensure valid nesting and consistent indentation."
    ],
    "accessibility": [
      "All form inputs must have associated labels.",
      "Interactive elements must be keyboard reachable.",
      "Images must include meaningful alt text or alt=\"\" when decorative.",
      "Color contrast should be reasonable; provide warnings when palette may violate WCAG."
    ],
    "performance": [
      "Avoid heavy inline SVG/data URIs unless requested.",
      "Prefer minimal CSS and no blocking external assets by default."
    ]
  },
  "examples": [
    {
      "name": "SaaS landing page (styled)",
      "input": {
        "request": "Create a SaaS landing page for an AI documentation tool with hero, features, testimonials, pricing, and CTA.",
        "mode": "styled",
        "page_type": "landing_page",
        "design": { "theme": "dark", "brand_tone": "minimal" },
        "output": { "format": "multi_file_bundle", "bundle_files": ["index.html", "styles.css", "app.js"] }
      }
    },
    {
      "name": "Documentation page from markdown (production)",
      "input": {
        "request": "Convert the provided markdown into a clean documentation page with a sticky sidebar and TOC.",
        "mode": "production",
        "page_type": "documentation_page",
        "content": { "markdown": "# Title\n\n## Section\n- Item 1\n- Item 2" },
        "quality": { "a11y_level": "wcag_aa", "seo_level": "enhanced", "performance_level": "optimized" }
      }
    }
  ]
}